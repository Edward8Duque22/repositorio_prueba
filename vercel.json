{
  "version": 2,
  "rewrites": [
    {
      "source": "/peticion/(.*)",
      "destination": "/index.js"
    }
  ],
  "headers": [
    {
      "source": "/peticion/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
